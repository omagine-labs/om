# Python Backend - Production Deployment Environment
# This file is used by deploy.sh to configure secrets in Google Cloud
# Copy this file to .env.deploy and fill in your production values

# Supabase Configuration (Production)
SUPABASE_URL=<your_production_supabase_url>
SUPABASE_SECRET_KEY=<your_production_service_role_key>

# AI Provider API Keys
GEMINI_API_KEY=<your_gemini_api_key>

# Transcription Provider Configuration
ASSEMBLYAI_API_KEY=<your_assemblyai_api_key>
TRANSCRIPTION_PROVIDER=assemblyai

# Backend API Key (for Edge Functions to authenticate)
# Generate with: openssl rand -base64 32
API_KEY=<your_production_api_key>

# =============================================================================
# Resend Configuration (for anonymous upload email notifications)
# =============================================================================
# Get API key from: https://resend.com/api-keys
# Used to send beautiful HTML emails when anonymous uploads complete processing
# Gracefully degrades if not configured - notifications will be skipped
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM_ADDRESS=notifications@omaginelabs.com
EMAIL_FROM_NAME=Om by Omagine Labs

# Frontend URL for generating signup links (default: https://app.omagine.com)
# FRONTEND_URL=https://app.omagine.com

# Note: The following are configured automatically by deploy.sh:
# - AI_PROVIDER defaults to 'gemini'
# - Secrets are stored in Google Secret Manager
# - Environment variables are injected into Cloud Run at deploy time
