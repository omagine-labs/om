# Python Backend - Local Development Environment
# Copy this file to .env.local and fill in your values

# =============================================================================
# Supabase Configuration (Auto-configured by setup script)
# =============================================================================
SUPABASE_URL=http://host.docker.internal:54321
# Service role key - auto-populated by npm run setup
# Or get manually: supabase status (look for "service_role key")
SUPABASE_SECRET_KEY=add_after_setting_up_supabase_db_locally

# =============================================================================
# AI Provider API Key (REQUIRED for AI Analysis)
# =============================================================================
# Get a free Gemini API key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# =============================================================================
# Transcription Provider Configuration (REQUIRED for Transcription)
# =============================================================================
# Get a free AssemblyAI API key: https://www.assemblyai.com/
ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here
# Options: 'assemblyai' (production) or 'mock' (local dev without API key)
TRANSCRIPTION_PROVIDER=assemblyai

# =============================================================================
# Server Configuration
# =============================================================================
PORT=8000

# API Key for authenticating Edge Function requests
# Generate with: openssl rand -base64 32
# For local dev, use any string or the same key as production
API_KEY=your_api_key_here

# =============================================================================
# Langfuse LLM Observability (OPTIONAL)
# =============================================================================
# Sign up at https://cloud.langfuse.com and create a project to get your keys
# Gracefully degrades if not configured - safe to leave as placeholders
LANGFUSE_PUBLIC_KEY=pk-lf-your_public_key_here
LANGFUSE_SECRET_KEY=sk-lf-your_secret_key_here
LANGFUSE_HOST=https://cloud.langfuse.com

# =============================================================================
# Sentry Error Tracking (OPTIONAL)
# =============================================================================
# Sign up at https://sentry.io and create a Python/FastAPI project to get your DSN
# Gracefully degrades if not configured - error tracking will be disabled
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# =============================================================================
# Resend Configuration (for anonymous upload email notifications)
# =============================================================================
# Get API key from: https://resend.com/api-keys
# Used to send beautiful HTML emails when anonymous uploads complete processing
# Gracefully degrades if not configured - notifications will be skipped
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM_ADDRESS=notifications@omaginelabs.com
EMAIL_FROM_NAME=Om by Omagine Labs

# Frontend URL for generating signup links in email notifications
# Default: https://app.omagine.com (production)
# For local development, use: http://localhost:3000
FRONTEND_URL=http://localhost:3000

# =============================================================================
# Stripe Configuration (for Stripe CLI container only - NOT used by Python backend)
# =============================================================================
# The Python backend does NOT use Stripe directly.
# This API key is only used by the Stripe CLI Docker container (defined in docker-compose.yml)
# to authenticate and forward webhook events to the frontend.
# Get test keys from: https://dashboard.stripe.com/test/apikeys
# Use the same value as STRIPE_SECRET_KEY from frontend/.env.local
STRIPE_API_KEY=sk_test_your_secret_key_here

# =============================================================================
# Notes
# =============================================================================
# The following are configured automatically:
# - AI_PROVIDER defaults to 'gemini'
# - HOST defaults to '0.0.0.0'
# - CORS is not needed (Edge Functions handle this in production)
