# Supabase Edge Functions - Environment Configuration
# Copy this file to .env (for local) or configure in Supabase Dashboard (for production)

# =============================================================================
# Python Backend Configuration
# =============================================================================

# LOCAL DEVELOPMENT
# Use host.docker.internal to access services running on host machine from Docker
PYTHON_BACKEND_URL=http://host.docker.internal:8000

# PRODUCTION / STAGING
# Use the Cloud Run URL from deployment
# PYTHON_BACKEND_URL=https://meeting-intelligence-backend-XXXXX-uc.a.run.app

# =============================================================================
# API Authentication
# =============================================================================

# API key for authenticating requests to Python backend
# Local development: Can be any string or omitted
PYTHON_BACKEND_API_KEY=local-dev-key-not-needed

# Production: Use the secret from Google Secret Manager
# This should match the API_KEY in python-backend deployment
# PYTHON_BACKEND_API_KEY=<production_api_key_from_secret_manager>

# =============================================================================
# Google OAuth Configuration (Local Development)
# =============================================================================
# Get from: Google Cloud Console → APIs & Services → Credentials
SUPABASE_AUTH_GOOGLE_CLIENT_ID=<your_google_oauth_client_id>
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=<your_google_oauth_client_secret>

# =============================================================================
# Microsoft OAuth Configuration (Local Development)
# =============================================================================
# Get from: Azure Portal → Microsoft Entra ID → App registrations → Your App
# Ensure redirect URI is configured: http://localhost:54321/auth/v1/callback

# Application (client) ID from Azure app registration
SUPABASE_AUTH_AZURE_CLIENT_ID=<your_azure_application_client_id>

# Client secret value from Azure app registration (Certificates & secrets)
SUPABASE_AUTH_AZURE_SECRET=<your_azure_client_secret>

# Azure URL for authentication endpoint
# Multitenant (supports any Microsoft account - personal or work): https://login.microsoftonline.com/common
# Single-tenant (only your organization): https://login.microsoftonline.com/{tenant-id}
# Work/school only (any organization): https://login.microsoftonline.com/organizations
# Personal accounts only: https://login.microsoftonline.com/consumers
SUPABASE_AUTH_AZURE_URL=https://login.microsoftonline.com/common

# =============================================================================
# Supabase Configuration (Automatically Available)
# =============================================================================
# These are automatically injected by Supabase in edge functions:
# - SUPABASE_URL
# - SUPABASE_ANON_KEY
# - SUPABASE_SERVICE_ROLE_KEY
# - SUPABASE_DB_URL
#
# You don't need to set these manually!
