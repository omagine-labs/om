# Supabase - Local Development Environment
# Edge Functions configuration for local development

# =============================================================================
# Python Backend Configuration
# =============================================================================

# LOCAL DEVELOPMENT
# Use host.docker.internal to access services running on host machine from Docker
PYTHON_BACKEND_URL=http://host.docker.internal:8000

# =============================================================================
# API Authentication
# =============================================================================

# API key for authenticating requests to Python backend
# Local development: Can be any string or omitted
PYTHON_BACKEND_API_KEY=local-dev-key-not-needed

# =============================================================================
# Supabase Configuration (Automatically Available)
# =============================================================================
# These are automatically injected by Supabase in edge functions:
# - SUPABASE_URL
# - SUPABASE_ANON_KEY
# - SUPABASE_SERVICE_ROLE_KEY
# - SUPABASE_DB_URL
#
# You don't need to set these manually!
