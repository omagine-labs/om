# Om Desktop Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# Supabase Configuration
# ============================================================================

# Environment mode: "local" or "production"
SUPABASE_ENV=local

# Local development (Supabase CLI: supabase start)
SUPABASE_URL_LOCAL=http://127.0.0.1:54321
SUPABASE_ANON_KEY_LOCAL=your_local_anon_key_here
VITE_SUPABASE_URL_LOCAL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY_LOCAL=your_local_anon_key_here
VITE_SUPABASE_ENV=local

# Production (from Supabase dashboard)
SUPABASE_URL_PRODUCTION=https://your-project.supabase.co
SUPABASE_ANON_KEY_PRODUCTION=your_production_anon_key_here
VITE_SUPABASE_URL_PRODUCTION=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY_PRODUCTION=your_production_anon_key_here

# ============================================================================
# Web App URLs
# ============================================================================

# Local development
WEB_APP_URL_LOCAL=http://localhost:3000
VITE_WEB_APP_URL_LOCAL=http://localhost:3000

# Production
WEB_APP_URL_PRODUCTION=https://app.yourdomain.com
VITE_WEB_APP_URL_PRODUCTION=https://app.yourdomain.com

# ============================================================================
# OAuth Configuration (Optional)
# ============================================================================

# Google OAuth Client ID (for calendar integration)
GOOGLE_CLIENT_ID=your_google_client_id

# Microsoft OAuth Client ID (for calendar integration)
MICROSOFT_CLIENT_ID=your_microsoft_client_id

# ============================================================================
# Sentry Error Tracking (Optional)
# ============================================================================

# Sentry DSN for error tracking and monitoring
# Get from: https://sentry.io/settings/your-project/keys/
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# ============================================================================
# Intercom (Product Tours & Announcements)
# ============================================================================

# Intercom App ID for product tours, announcements, and tooltips
# Get from: Intercom Settings → Installation → Web
VITE_INTERCOM_APP_ID=your_intercom_app_id_here

# ============================================================================
# Apple Developer Credentials (Production Builds Only)
# ============================================================================

# Required for code signing and notarization
# Only needed when running: npm run make:production

# Developer ID Application certificate
APPLE_IDENTITY="Developer ID Application: Your Name (TEAM_ID)"

# Apple Developer Team ID (10-character string)
APPLE_TEAM_ID=ABCD123456

# Apple ID email
APPLE_ID=your-apple-id@example.com

# App-specific password (generate at appleid.apple.com)
# NOT your Apple ID password - must be app-specific password
APPLE_APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ============================================================================
# Notes
# ============================================================================

# Development:
# - Use SUPABASE_ENV=local to connect to local Supabase (supabase start)
# - No need to fill in Apple Developer credentials for development
# - OAuth client IDs are optional (only needed for calendar integration)

# Production Builds:
# - Use SUPABASE_ENV=production for production builds
# - Apple Developer credentials are REQUIRED for signed builds
# - Without signing, builds will show security warnings to users

# Get Supabase keys:
# - Local: Run `supabase status` after `supabase start`
# - Production: Supabase Dashboard → Settings → API

# Get OAuth Client IDs:
# - Google: https://console.cloud.google.com/apis/credentials
# - Microsoft: https://portal.azure.com/ → App registrations

# Get Apple Developer credentials:
# - Team ID: https://developer.apple.com/account → Membership
# - App-specific password: https://appleid.apple.com/ → App-Specific Passwords
# - Identity: Use certificate name from Keychain Access
