# Frontend - Local Development Environment
# Copy this file to .env.local and fill in your values

# =============================================================================
# Environment Selector
# =============================================================================
# Set to 'local' or 'production'
# Change this single variable to switch between local and production Supabase
NEXT_PUBLIC_SUPABASE_ENV=local
#NEXT_PUBLIC_SUPABASE_ENV=production

# =============================================================================
# Local Supabase Configuration (Auto-configured by setup script)
# =============================================================================
# These keys are auto-populated when you run: npm run setup
# Or get manually:
#   1. Start Supabase: supabase start
#   2. Look for "anon key:" in the output
#   3. Or run: supabase status
NEXT_PUBLIC_SUPABASE_URL_LOCAL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY_LOCAL=your_local_anon_key_here

# =============================================================================
# Production Supabase Configuration
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL_PRODUCTION=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY_PRODUCTION=<ask_team_for_production_anon_key>

# =============================================================================
# Python Backend Configuration
# =============================================================================
# For local development: use http://localhost:8000 (default, can be omitted)
# For production: ask team for the Cloud Run URL
PYTHON_BACKEND_URL=<ask_team_for_python_backend_url>

# API key for authenticating with Python backend
# For local development: copy API_KEY value from python-backend/.env.local
# For production: ask team for production API key
PYTHON_BACKEND_API_KEY=<copy_from_python_backend_env>

# =============================================================================
# Development Settings
# =============================================================================
NODE_ENV=development

# Disable rate limiting for testing (set to 'true' to disable, remove or set to 'false' to enable)
# Useful when testing subscription flows, webhooks, or any feature that makes multiple API calls
# IMPORTANT: Remove this or set to 'false' in production!
# DISABLE_RATE_LIMITING=true

# =============================================================================
# Analytics - PostHog
# =============================================================================
# Get your project API key from: https://app.posthog.com/project/settings
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_api_key_here
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# =============================================================================
# Customer Communication - Intercom
# =============================================================================
# Get your App ID from: Intercom Settings → Installation → Web
NEXT_PUBLIC_INTERCOM_APP_ID=your_intercom_app_id_here

# Identity Verification Secret (SERVER-SIDE ONLY - never exposed to browser)
# Get from: Intercom Settings → Security → Identity Verification
# IMPORTANT: This is required for JWT-based identity verification
INTERCOM_IDENTITY_VERIFICATION_SECRET=your_intercom_identity_secret_here

# =============================================================================
# OAuth Providers (OPTIONAL - for Google/Microsoft login)
# =============================================================================
# Google OAuth
# Get from: https://console.cloud.google.com/apis/credentials
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Microsoft OAuth
# Get from: https://portal.azure.com/ → Microsoft Entra ID → App registrations
NEXT_PUBLIC_MICROSOFT_CLIENT_ID=your_microsoft_client_id_here
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret_here

# =============================================================================
# Stripe Configuration (REQUIRED for Subscription Features)
# =============================================================================
# Get test keys from: https://dashboard.stripe.com/test/apikeys

# Publishable key (public, safe to use in browser)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Secret key (server-side only, never exposed to browser)
STRIPE_SECRET_KEY=sk_test_your_secret_key_here

# Webhook signing secret (for verifying webhook signatures)
# Setup steps (after running npm start):
#   1. Add STRIPE_API_KEY to python-backend/.env.local (for Stripe CLI container):
#      STRIPE_API_KEY=sk_test_xxx (same value as STRIPE_SECRET_KEY above)
#   2. Recreate Stripe CLI container to load the API key:
#      cd python-backend && docker-compose up -d --force-recreate stripe-cli
#   3. Wait a few seconds for Stripe CLI to start, then get webhook secret:
#      sleep 5 && docker logs stripe-webhook-forwarder 2>&1 | grep -A 2 'Ready!'
#   4. Add the secret below (look for "whsec_" in the output)
#   5. Restart frontend
# Production: Get from Stripe Dashboard → Developers → Webhooks
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Stripe Price IDs (REQUIRED)
# Test mode: Get from Stripe Dashboard → Products → [Your Product] → Pricing
# Production: Create products in live mode and copy price IDs
NEXT_PUBLIC_STRIPE_MONTHLY_PRICE_ID=price_your_monthly_price_id
NEXT_PUBLIC_STRIPE_ANNUAL_PRICE_ID=price_your_annual_price_id

# Internal Team Coupon (REQUIRED)
# Create a coupon in Stripe Dashboard → Products → Coupons (100% off, forever)
# Test mode and production mode will have different coupon IDs
NEXT_PUBLIC_STRIPE_INTERNAL_COUPON_ID=your_coupon_id

# =============================================================================
# Sentry Error Tracking (OPTIONAL)
# =============================================================================
# Get from: https://sentry.io/settings/your-project/keys/
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
# For source map uploads (production only)
SENTRY_AUTH_TOKEN=your_sentry_auth_token_here
SENTRY_ORG=your_org_name
SENTRY_PROJECT=om  # or om-frontend if using separate projects

# =============================================================================
# Service Role Key (Auto-configured by setup script)
# =============================================================================
# Server-side only - bypasses RLS
# Auto-populated by: npm run setup
# Or get manually: supabase status (look for "service_role key")
# WARNING: Never expose this in client-side code!
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

